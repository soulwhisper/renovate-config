{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":approveMajorUpdates",
    ":disableRateLimiting",
    ":docker",
    "github>soulwhisper/renovate-config:labels",
    "github>soulwhisper/renovate-config:automerge",
    "github>soulwhisper/renovate-config:commit-message",
    "github>soulwhisper/renovate-config:semantic-commits",
    "github>soulwhisper/renovate-config:custom-managers.json5"
  ],
  "ignorePresets": [":ignoreModulesAndTests"],
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/examples/**",
    "**/__fixtures__/**"
  ],
  "timezone": "Asia/Shanghai",
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": ["prIgnoreNotification"],
  "commitBodyTable": true,
  "rebaseWhen": "auto",
  "platformCommit": "enabled"
}
